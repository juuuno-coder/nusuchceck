<% content_for :title, "의견 보내기" %>

<div class="min-h-screen bg-gradient-to-br from-blue-50 via-white to-purple-50 py-12">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- 헤더 -->
    <div class="text-center mb-8">
      <div class="inline-flex items-center px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-sm font-medium mb-3">
        💬 Feedback
      </div>
      <h1 class="text-4xl font-bold text-gray-900 mb-3">의견 보내기</h1>
      <p class="text-lg text-gray-600">
        누수체크 서비스를 개선하는 데 도움을 주세요
      </p>
    </div>

    <!-- 피드백 폼 -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8">
      <%= form_with model: @feedback, url: feedbacks_path, html: { class: "space-y-6" } do |f| %>
        <% if @feedback.errors.any? %>
          <div class="bg-red-50 border border-red-200 rounded-lg p-4">
            <h3 class="text-sm font-semibold text-red-800 mb-2">입력 오류가 있습니다</h3>
            <ul class="text-sm text-red-700 space-y-1 list-disc list-inside">
              <% @feedback.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <!-- 이름 -->
        <div>
          <%= f.label :name, "이름", class: "block text-sm font-semibold text-gray-700 mb-2" %>
          <%= f.text_field :name,
                value: current_user&.name,
                placeholder: "홍길동",
                required: true,
                class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" %>
        </div>

        <!-- 이메일 -->
        <div>
          <%= f.label :email, "이메일", class: "block text-sm font-semibold text-gray-700 mb-2" %>
          <%= f.email_field :email,
                value: current_user&.email,
                placeholder: "your@email.com",
                required: true,
                class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" %>
          <p class="mt-1 text-xs text-gray-500">답변이 필요한 경우 연락드리겠습니다</p>
        </div>

        <!-- 카테고리 -->
        <div>
          <%= f.label :category, "분류", class: "block text-sm font-semibold text-gray-700 mb-2" %>
          <%= f.select :category,
                options_for_select(Feedback::CATEGORIES.map { |c| [c, c] }),
                { prompt: "분류를 선택하세요" },
                required: true,
                class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition" %>
        </div>

        <!-- 메시지 -->
        <div>
          <%= f.label :message, "의견 내용", class: "block text-sm font-semibold text-gray-700 mb-2" %>
          <%= f.text_area :message,
                rows: 6,
                placeholder: "개선이 필요한 부분이나 제안사항을 자유롭게 작성해주세요 (최소 10자 이상)",
                required: true,
                class: "w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent transition resize-none" %>
          <p class="mt-1 text-xs text-gray-500">최소 10자 이상 입력해주세요</p>
        </div>

        <!-- 제출 버튼 -->
        <div class="flex gap-3 pt-4">
          <%= link_to "취소", :back, class: "flex-1 px-6 py-3 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors font-semibold text-center" %>
          <%= f.submit "의견 보내기", class: "flex-1 px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors font-semibold" %>
        </div>
      <% end %>
    </div>

    <!-- 안내 -->
    <div class="mt-6 bg-blue-50 border border-blue-100 rounded-xl p-5">
      <div class="flex items-start gap-3">
        <svg class="w-5 h-5 text-blue-600 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
        </svg>
        <div class="flex-1">
          <p class="text-sm text-blue-800">
            <strong>보내주신 의견은 서비스 개선에 큰 도움이 됩니다.</strong><br>
            검토 후 답변이 필요한 경우 이메일로 연락드리겠습니다.
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- 토스 스타일 고객 앱 랜딩페이지 -->
<div class="min-h-screen bg-gradient-to-br from-primary-50 via-white to-purple-50">
  <!-- 히어로 섹션 -->
  <div class="max-w-6xl mx-auto px-4 pt-20 pb-16">
    <!-- 메인 캐치프레이즈 -->
    <div class="text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary-100 rounded-full mb-6">
        <span class="w-2 h-2 bg-primary-600 rounded-full animate-pulse"></span>
        <span class="text-sm font-bold text-primary-700">AI 기반 누수 진단 플랫폼</span>
      </div>

      <h1 class="text-5xl md:text-6xl font-extrabold text-gray-900 mb-6 leading-tight">
        누수, <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary-600 to-purple-600">10분</span>이면<br class="md:hidden"/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-pink-600">해결됩니다</span>
      </h1>

      <p class="text-xl md:text-2xl text-gray-600 mb-10 leading-relaxed">
        영상 하나로 AI가 진단하고,<br class="md:hidden"/>
        검증된 전문가가 24시간 내 견적을 드려요
      </p>

      <!-- CTA 버튼 -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-12">
        <%= link_to new_user_registration_path, class: "w-full sm:w-auto inline-flex items-center justify-center gap-3 px-8 py-5 bg-gradient-to-r from-primary-600 to-purple-600 text-white rounded-2xl hover:shadow-2xl transition-all font-bold text-lg group" do %>
          <svg class="w-6 h-6 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 20 20">
            <path d="M2 6a2 2 0 012-2h6a2 2 0 012 2v8a2 2 0 01-2 2H4a2 2 0 01-2-2V6zM14.553 7.106A1 1 0 0014 8v4a1 1 0 00.553.894l2 1A1 1 0 0018 13V7a1 1 0 00-1.447-.894l-2 1z"/>
          </svg>
          <span>지금 바로 시작하기</span>
        <% end %>

        <%= link_to new_user_session_path, class: "w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-5 bg-white text-gray-700 rounded-2xl hover:bg-gray-50 transition-all font-semibold text-lg border-2 border-gray-200" do %>
          <span>이미 회원이에요</span>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
        <% end %>
      </div>

      <!-- 신뢰 지표 -->
      <div class="flex flex-wrap items-center justify-center gap-8 text-sm text-gray-600">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-green-600" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span class="font-semibold">평균 응답시간 2시간</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-blue-600" fill="currentColor" viewBox="0 0 20 20">
            <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
          </svg>
          <span class="font-semibold">고객 만족도 4.8/5.0</span>
        </div>
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-purple-600" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span class="font-semibold">검증된 전문가 500+</span>
        </div>
      </div>
    </div>

    <!-- 프로세스 (토스 스타일 컬러풀 카드) -->
    <div class="grid md:grid-cols-3 gap-6 mb-20">
      <!-- Step 1 -->
      <div class="group bg-gradient-to-br from-blue-50 to-blue-100 rounded-3xl p-8 border-2 border-blue-200 hover:shadow-2xl transition-all hover:-translate-y-2">
        <div class="w-16 h-16 bg-gradient-to-br from-blue-600 to-blue-700 rounded-2xl flex items-center justify-center mb-6 shadow-lg group-hover:scale-110 transition-transform">
          <span class="text-3xl">📹</span>
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-3">1. 영상 촬영</h3>
        <p class="text-gray-700 leading-relaxed">
          누수 부위를 10초 이상 촬영하세요.<br/>
          AI가 자동으로 분석해드려요.
        </p>
      </div>

      <!-- Step 2 -->
      <div class="group bg-gradient-to-br from-purple-50 to-purple-100 rounded-3xl p-8 border-2 border-purple-200 hover:shadow-2xl transition-all hover:-translate-y-2">
        <div class="w-16 h-16 bg-gradient-to-br from-purple-600 to-purple-700 rounded-2xl flex items-center justify-center mb-6 shadow-lg group-hover:scale-110 transition-transform">
          <span class="text-3xl">🤖</span>
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-3">2. AI 진단</h3>
        <p class="text-gray-700 leading-relaxed">
          24시간 내 검증된 전문가가<br/>
          정확한 견적을 제공해드려요.
        </p>
      </div>

      <!-- Step 3 -->
      <div class="group bg-gradient-to-br from-pink-50 to-pink-100 rounded-3xl p-8 border-2 border-pink-200 hover:shadow-2xl transition-all hover:-translate-y-2">
        <div class="w-16 h-16 bg-gradient-to-br from-pink-600 to-pink-700 rounded-2xl flex items-center justify-center mb-6 shadow-lg group-hover:scale-110 transition-transform">
          <span class="text-3xl">✅</span>
        </div>
        <h3 class="text-2xl font-bold text-gray-900 mb-3">3. 안심 수리</h3>
        <p class="text-gray-700 leading-relaxed">
          에스크로 결제로 안전하게,<br/>
          보험청구까지 자동으로 처리해요.
        </p>
      </div>
    </div>

    <!-- 특징 -->
    <div class="bg-white rounded-3xl p-10 shadow-xl border border-gray-100 mb-16">
      <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">
        왜 <span class="text-primary-600">누수체크</span>일까요?
      </h2>

      <div class="grid md:grid-cols-2 gap-8">
        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-primary-100 rounded-xl flex items-center justify-center">
            <svg class="w-7 h-7 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/>
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-gray-900 mb-2 text-lg">빠른 응답</h4>
            <p class="text-gray-600">영상 업로드 후 평균 2시간 내 견적 제공</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-green-100 rounded-xl flex items-center justify-center">
            <svg class="w-7 h-7 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-gray-900 mb-2 text-lg">안전 결제</h4>
            <p class="text-gray-600">에스크로로 완료 후 결제, 환불 보장</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-purple-100 rounded-xl flex items-center justify-center">
            <svg class="w-7 h-7 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-gray-900 mb-2 text-lg">보험 자동화</h4>
            <p class="text-gray-600">서류 자동 생성, 클릭 한 번에 보험 청구</p>
          </div>
        </div>

        <div class="flex items-start gap-4">
          <div class="flex-shrink-0 w-12 h-12 bg-orange-100 rounded-xl flex items-center justify-center">
            <svg class="w-7 h-7 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <div>
            <h4 class="font-bold text-gray-900 mb-2 text-lg">투명한 가격</h4>
            <p class="text-gray-600">표준 견적으로 합리적인 가격 보장</p>
          </div>
        </div>
      </div>
    </div>

    <!-- 최종 CTA -->
    <div class="text-center bg-gradient-to-r from-primary-600 to-purple-600 rounded-3xl p-12 shadow-2xl">
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-4">
        누수 걱정, 이제 그만하세요
      </h2>
      <p class="text-xl text-primary-100 mb-8">
        지금 바로 시작하고 24시간 내 견적 받아보세요
      </p>
      <%= link_to new_user_registration_path, class: "inline-flex items-center gap-3 px-10 py-6 bg-white text-primary-600 rounded-2xl hover:shadow-2xl transition-all font-bold text-xl group" do %>
        <span>무료로 시작하기</span>
        <svg class="w-6 h-6 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
        </svg>
      <% end %>
    </div>
  </div>
</div>

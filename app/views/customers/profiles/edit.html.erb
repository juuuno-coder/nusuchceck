<%# 프로필 수정 %>
<div class="max-w-lg mx-auto px-4 py-6">

  <%= link_to customers_profile_path, class: "inline-flex items-center text-sm text-gray-500 hover:text-gray-700 mb-4" do %>
    <svg class="w-4 h-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    돌아가기
  <% end %>

  <!-- 프로필 카드 -->
  <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden mb-4">
    <div class="bg-gradient-to-br from-primary-50 to-blue-50 px-5 py-6 text-center">
      <div class="relative w-20 h-20 mx-auto mb-3">
        <% if @customer.has_avatar? %>
          <% if @customer.avatar.attached? %>
            <%= image_tag @customer.avatar.variant(resize_to_fill: [80, 80]), class: "w-20 h-20 rounded-full object-cover shadow-md" %>
          <% else %>
            <img src="<%= @customer.avatar_url %>" class="w-20 h-20 rounded-full object-cover shadow-md" referrerpolicy="no-referrer">
          <% end %>
        <% else %>
          <div class="w-20 h-20 bg-gradient-to-br from-primary-400 to-primary-600 rounded-full flex items-center justify-center text-white text-3xl font-bold shadow-md">
            <%= @customer.name&.first || "?" %>
          </div>
        <% end %>
        <label for="avatar-upload" class="absolute -bottom-1 -right-1 w-7 h-7 bg-white rounded-full shadow border border-gray-200 flex items-center justify-center cursor-pointer hover:bg-gray-50 transition">
          <svg class="w-3.5 h-3.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        </label>
      </div>
      <p class="text-lg font-bold text-gray-900"><%= @customer.name || "이름 없음" %></p>
      <p class="text-xs text-gray-500 mt-0.5"><%= @customer.email %></p>

      <!-- 아바타 업로드 (숨김) -->
      <%= form_with url: customers_profile_path, method: :patch, multipart: true, class: "hidden", id: "avatar-form" do |f| %>
        <%= f.file_field :avatar, id: "avatar-upload", accept: "image/*",
              onchange: "document.getElementById('avatar-form').requestSubmit()" %>
      <% end %>
    </div>

    <!-- 소셜 연동 -->
    <div class="divide-y divide-gray-50 px-5">
      <%
        socials = [
          { provider: "kakao", name: "카카오", color: "#FEE500", text_color: "#191919",
            path: user_kakao_omniauth_authorize_path },
          { provider: "naver", name: "네이버", color: "#03C75A", text_color: "#fff",
            path: user_naver_omniauth_authorize_path },
          { provider: "google_oauth2", name: "구글", color: "#4285F4", text_color: "#fff",
            path: user_google_oauth2_omniauth_authorize_path }
        ]
      %>
      <% socials.each do |s| %>
        <div class="flex items-center justify-between py-3">
          <span class="text-sm text-gray-700 font-medium"><%= s[:name] %></span>
          <% if @customer.provider == s[:provider] %>
            <span class="text-xs font-medium text-green-600 bg-green-50 px-2.5 py-1 rounded-full">연동됨</span>
          <% else %>
            <%= button_to s[:path], method: :post, data: { turbo: false },
                  class: "text-xs font-semibold text-primary-600 hover:text-primary-800 transition",
                  form: { class: "inline" } do %>
              연동하기
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- 수정 폼 -->
  <div class="bg-white rounded-2xl border border-gray-100 p-5" data-controller="address-search">
    <h2 class="text-sm font-bold text-gray-500 mb-4">기본 정보 수정</h2>

    <%= form_with(model: @customer, url: customers_profile_path, method: :patch, class: "space-y-4") do |f| %>

      <%= render "shared/form_errors", resource: @customer %>

      <div>
        <%= f.label :name, "닉네임", class: "block text-xs font-semibold text-gray-500 mb-1.5" %>
        <%= f.text_field :name, placeholder: "표시될 이름을 입력해주세요",
              class: "w-full text-sm border border-gray-200 rounded-xl px-3 py-2.5 focus:ring-2 focus:ring-primary-400 focus:outline-none" %>
      </div>

      <div>
        <%= f.label :phone, "전화번호", class: "block text-xs font-semibold text-gray-500 mb-1.5" %>
        <%= f.text_field :phone, placeholder: "010-0000-0000",
              class: "w-full text-sm border border-gray-200 rounded-xl px-3 py-2.5 focus:ring-2 focus:ring-primary-400 focus:outline-none" %>
      </div>

      <div>
        <%= f.label :address, "주소", class: "block text-xs font-semibold text-gray-500 mb-1.5" %>
        <div class="cursor-pointer" data-action="click->address-search#open">
          <%= f.text_field :address, placeholder: "주소를 검색하세요", readonly: true,
                data: { address_search_target: "address", action: "click->address-search#open" },
                class: "w-full text-sm border border-gray-200 rounded-xl px-3 py-2.5 focus:ring-2 focus:ring-primary-400 focus:outline-none cursor-pointer" %>
        </div>
      </div>

      <div class="flex items-center justify-end gap-2 pt-4 border-t border-gray-100">
        <%= link_to "취소", customers_profile_path, class: "px-4 py-2.5 text-sm font-medium text-gray-600 hover:text-gray-800 transition" %>
        <%= f.submit "저장하기", class: "px-6 py-2.5 bg-primary-600 text-white text-sm font-bold rounded-xl hover:bg-primary-700 transition cursor-pointer" %>
      </div>
    <% end %>
  </div>

</div>

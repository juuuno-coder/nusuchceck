<div class="max-w-lg mx-auto">
  <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 md:p-10">
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-gray-900">회원가입</h1>
      <p class="mt-2 text-gray-500">누수체크에 가입하고 편리하게 서비스를 이용하세요</p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { class: "space-y-5" }) do |f| %>
      <% if resource.errors.any? %>
        <div class="bg-red-50 border border-red-200 rounded-lg p-4">
          <div class="flex items-center mb-2">
            <svg class="w-5 h-5 text-red-500 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="text-red-800 font-semibold text-sm"><%= pluralize(resource.errors.count, "개의 오류") %>가 있습니다:</span>
          </div>
          <ul class="list-disc list-inside text-sm text-red-700 space-y-1">
            <% resource.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <!-- 고객으로 자동 설정 -->
      <%= f.hidden_field :type, value: "Customer" %>

      <!-- 이름 -->
      <div>
        <label for="user_name" class="block text-sm font-semibold text-gray-700 mb-1">이름 <span class="text-red-500">*</span></label>
        <%= f.text_field :name, autofocus: true, autocomplete: "name", placeholder: "홍길동", class: input_classes(:text) %>
      </div>

      <!-- 이메일 -->
      <div>
        <label for="user_email" class="block text-sm font-semibold text-gray-700 mb-1">이메일 <span class="text-red-500">*</span></label>
        <%= f.email_field :email, autocomplete: "email", placeholder: "example@email.com", class: input_classes(:text) %>
      </div>

      <!-- 비밀번호 -->
      <div>
        <label for="user_password" class="block text-sm font-semibold text-gray-700 mb-1">비밀번호 <span class="text-red-500">*</span></label>
        <%= f.password_field :password, autocomplete: "new-password", placeholder: "6자 이상 입력", class: input_classes(:text) %>
        <p class="mt-1 text-xs text-gray-500">
          <% if @minimum_password_length %>
            최소 <%= @minimum_password_length %>자 이상
          <% end %>
        </p>
      </div>

      <!-- 비밀번호 확인 -->
      <div>
        <label for="user_password_confirmation" class="block text-sm font-semibold text-gray-700 mb-1">비밀번호 확인 <span class="text-red-500">*</span></label>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", placeholder: "비밀번호를 다시 입력", class: input_classes(:text) %>
      </div>

      <!-- 전화번호 -->
      <div>
        <label for="user_phone" class="block text-sm font-semibold text-gray-700 mb-1">전화번호</label>
        <%= f.telephone_field :phone, autocomplete: "tel", placeholder: "010-1234-5678", class: input_classes(:text) %>
        <p class="mt-1 text-xs text-gray-500">누수 발생 시 연락받으실 번호예요</p>
      </div>

      <!-- 가입 버튼 -->
      <div class="pt-2">
        <%= f.submit "회원가입", class: "w-full #{btn_classes(:primary, :lg)}" %>
      </div>
    <% end %>

    <!-- 하단 링크 -->
    <div class="mt-6 text-center text-sm text-gray-500">
      <%= render "devise/shared/links" %>
    </div>

    <!-- 전문가 가입 안내 -->
    <div class="mt-4 p-4 bg-gray-50 rounded-lg border border-gray-200 text-center">
      <p class="text-sm text-gray-600">
        누수 탐지/시공 전문가이신가요?
      </p>
      <a href="/expert" class="inline-flex items-center mt-2 text-sm font-semibold text-blue-700 hover:text-blue-800">
        전문가 가입 페이지로 이동
        <svg class="w-4 h-4 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
    </div>
  </div>
</div>

<!DOCTYPE html>
<html lang="ko">
<head>
  <title>누수체크 - 누수 전문 매칭 플랫폼</title>
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover">
  <meta charset="utf-8">
  <meta name="theme-color" content="#ffffff">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <link rel="manifest" href="/manifest.json">
  <link rel="apple-touch-icon" href="/icon-192.png">
  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>
  <link rel="stylesheet" as="style" crossorigin
        href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css" />
  <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  <%= javascript_importmap_tags %>
</head>
<body class="bg-white min-h-screen flex flex-col font-sans<%= ' native-app' if hotwire_native_app? %>">
  <!-- Loading Progress Bar -->
  <div data-controller="loading">
    <div data-loading-target="bar" class="loading-bar hidden"></div>
  </div>

  <!-- 상단 헤더 (당근마켓 스타일 - 흰색 배경) -->
  <% unless hotwire_native_app? %>
  <header class="bg-white border-b border-gray-100 sticky top-0 z-50" data-controller="mobile-menu">
    <div class="max-w-lg mx-auto px-4 md:max-w-7xl md:px-6 lg:px-8">
      <div class="flex justify-between items-center h-14">
        <!-- 좌: 로고 -->
        <div class="flex items-center">
          <%= link_to root_path, class: "flex items-center" do %>
            <span class="text-xl font-bold text-gray-900">누수체크</span>
          <% end %>
        </div>

        <!-- 데스크톱 네비게이션 -->
        <% if user_signed_in? %>
          <nav class="hidden md:flex items-center space-x-1">
            <% if current_user.customer? %>
              <%= link_to "내 체크", customers_requests_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors" %>
              <%= link_to "보험 신청", customers_insurance_claims_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors" %>
            <% elsif current_user.master? %>
              <%= link_to "대시보드", expert_dashboard_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors" %>
              <%= link_to "공개 오더", open_orders_masters_requests_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors" %>
              <%= link_to "내 오더", masters_requests_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors" %>
              <%= link_to "정산", expert_settlements_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors" %>
            <% elsif current_user.admin? %>
              <%= link_to "대시보드", admin_root_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors" %>
              <%= link_to "체크관리", admin_requests_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors" %>
              <%= link_to "마스터관리", admin_masters_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors" %>
              <%= link_to "에스크로", admin_escrow_transactions_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors" %>
              <%= link_to "보험관리", admin_insurance_claims_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors" %>
              <%= link_to "의견관리", admin_feedbacks_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors" %>
              <%= link_to "설문조사", admin_surveys_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors" %>
            <% end %>
          </nav>
        <% else %>
          <nav class="hidden md:flex items-center space-x-1">
            <%= link_to "AI 진단", new_leak_inspection_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors" %>
            <%= link_to "서비스 소개", about_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors" %>
            <%= link_to "가격안내", pricing_path, class: "px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-50 transition-colors" %>
          </nav>
        <% end %>

        <!-- 우: 아이콘 액션 -->
        <div class="flex items-center space-x-1">
          <% if user_signed_in? %>
            <!-- 알림 벨 -->
            <%= render "shared/notifications_dropdown" %>

            <!-- 데스크톱: 사용자 메뉴 -->
            <div class="hidden md:flex items-center ml-2 space-x-2">
              <span class="text-sm text-gray-600"><%= current_user.name %></span>
              <%= button_to "로그아웃", destroy_user_session_path, method: :delete, class: "px-3 py-1.5 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-100 transition-colors" %>
            </div>
          <% else %>
            <div class="hidden md:flex items-center space-x-2">
              <%= link_to "로그인", new_user_session_path, class: "px-4 py-2 rounded-lg text-sm font-medium text-gray-600 hover:bg-gray-50 transition-colors" %>
              <%= link_to "회원가입", new_user_registration_path, class: "px-4 py-2 rounded-xl text-sm font-semibold bg-primary-600 text-white hover:bg-primary-700 transition-colors" %>
            </div>
          <% end %>

          <!-- 모바일 햄버거 버튼 -->
          <button type="button"
                  class="md:hidden inline-flex items-center justify-center p-2 rounded-lg text-gray-500 hover:bg-gray-50 focus:outline-none"
                  data-action="mobile-menu#toggle"
                  data-mobile-menu-target="button"
                  aria-expanded="false"
                  aria-label="메뉴 열기">
            <svg class="h-6 w-6" data-mobile-menu-target="iconOpen" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <svg class="h-6 w-6 hidden" data-mobile-menu-target="iconClose" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>
    </div>

    <!-- 모바일 메뉴 패널 -->
    <div class="md:hidden hidden" data-mobile-menu-target="panel">
      <div class="px-4 pt-2 pb-4 space-y-1 border-t border-gray-100 mobile-menu-enter bg-white">
        <% if user_signed_in? %>
          <div class="py-3 border-b border-gray-100 mb-2">
            <p class="px-3 text-sm font-semibold text-gray-900"><%= current_user.name %></p>
            <p class="px-3 text-xs text-gray-500"><%= current_user.display_role %></p>
          </div>
          <% if current_user.customer? %>
            <%= link_to "내 체크", customers_requests_path, class: "block px-3 py-2.5 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
            <%= link_to "보험 신청", customers_insurance_claims_path, class: "block px-3 py-2.5 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
            <%= link_to "AI 진단", new_leak_inspection_path, class: "block px-3 py-2.5 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
          <% elsif current_user.master? %>
            <%= link_to "대시보드", expert_dashboard_path, class: "block px-3 py-2.5 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
            <%= link_to "공개 오더", open_orders_masters_requests_path, class: "block px-3 py-2.5 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
            <%= link_to "내 오더", masters_requests_path, class: "block px-3 py-2.5 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
            <%= link_to "정산", expert_settlements_path, class: "block px-3 py-2.5 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
            <%= link_to "내 프로필", masters_profile_path, class: "block px-3 py-2.5 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
          <% elsif current_user.admin? %>
            <%= link_to "대시보드", admin_root_path, class: "block px-3 py-2.5 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
            <%= link_to "체크관리", admin_requests_path, class: "block px-3 py-2.5 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
            <%= link_to "마스터관리", admin_masters_path, class: "block px-3 py-2.5 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
            <%= link_to "에스크로", admin_escrow_transactions_path, class: "block px-3 py-2.5 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
            <%= link_to "보험관리", admin_insurance_claims_path, class: "block px-3 py-2.5 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
            <%= link_to "의견관리", admin_feedbacks_path, class: "block px-3 py-2.5 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
            <%= link_to "설문조사", admin_surveys_path, class: "block px-3 py-2.5 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
          <% end %>
          <div class="border-t border-gray-100 mt-2 pt-2">
            <%= button_to "로그아웃", destroy_user_session_path, method: :delete, class: "w-full text-left px-3 py-2.5 rounded-lg text-base font-medium text-red-500 hover:bg-red-50" %>
          </div>
        <% else %>
          <%= link_to "AI 진단", new_leak_inspection_path, class: "block px-3 py-2.5 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
          <%= link_to "서비스 소개", about_path, class: "block px-3 py-2.5 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
          <%= link_to "가격안내", pricing_path, class: "block px-3 py-2.5 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
          <div class="border-t border-gray-100 mt-2 pt-2 space-y-2">
            <%= link_to "로그인", new_user_session_path, class: "block px-3 py-2.5 rounded-lg text-base font-medium text-gray-700 hover:bg-gray-50" %>
            <%= link_to "회원가입", new_user_registration_path, class: "block px-3 py-3 rounded-xl text-base font-semibold bg-primary-600 text-white text-center hover:bg-primary-700" %>
          </div>
        <% end %>
      </div>
    </div>
  </header>
  <% end %>

  <!-- Flash messages -->
  <%= render "shared/flash_messages" %>

  <!-- Main content -->
  <main class="flex-grow w-full<%= hotwire_native_app? ? ' px-4 py-4' : '' %>">
    <div class="<%= controller_name == 'pages' ? '' : 'max-w-lg mx-auto md:max-w-7xl px-4 md:px-6 lg:px-8 py-4 md:py-8' %>">
      <%= yield %>
    </div>
  </main>

  <!-- 하단 탭 네비게이션 (모바일 - 모든 사용자) -->
  <% unless hotwire_native_app? %>
    <nav class="md:hidden fixed bottom-0 left-0 right-0 bottom-tab-bar z-40" aria-label="하단 탭 메뉴">
      <div class="grid grid-cols-5 h-14">
        <% if user_signed_in? && current_user.customer? %>
          <%# 고객용 5탭: 홈 / AI진단 / 체크하기(+) / 채팅 / 마이페이지 %>
          <%= link_to root_path, class: "bottom-tab-item #{controller_name == 'pages' ? 'active' : ''}" do %>
            <svg class="w-6 h-6" fill="<%= controller_name == 'pages' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="<%= controller_name == 'pages' ? '0' : '1.5' %>" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            <span>홈</span>
          <% end %>

          <%= link_to new_leak_inspection_path, class: "bottom-tab-item #{controller_name == 'leak_inspections' ? 'active' : ''}" do %>
            <svg class="w-6 h-6" fill="<%= controller_name == 'leak_inspections' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <span>AI진단</span>
          <% end %>

          <%= link_to new_customers_request_path, class: "bottom-tab-item", data: { turbo: false } do %>
            <div class="w-10 h-10 -mt-4 bg-primary-600 rounded-full flex items-center justify-center shadow-lg">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
              </svg>
            </div>
            <span class="-mt-1 text-primary-600 font-semibold">체크</span>
          <% end %>

          <%= link_to notifications_path, class: "bottom-tab-item #{controller_name == 'notifications' ? 'active' : ''}" do %>
            <svg class="w-6 h-6" fill="<%= controller_name == 'notifications' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
            </svg>
            <span>알림</span>
          <% end %>

          <%= link_to customers_profile_path, class: "bottom-tab-item #{controller_name == 'profiles' ? 'active' : ''}" do %>
            <svg class="w-6 h-6" fill="<%= controller_name == 'profiles' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            <span>마이</span>
          <% end %>

        <% elsif user_signed_in? && current_user.master? %>
          <%# 전문가용 5탭: 홈 / 공개오더 / 내오더 / 채팅 / 마이페이지 %>
          <%= link_to expert_dashboard_path, class: "bottom-tab-item #{controller_name == 'dashboard' ? 'active' : ''}" do %>
            <svg class="w-6 h-6" fill="<%= controller_name == 'dashboard' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="<%= controller_name == 'dashboard' ? '0' : '1.5' %>" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            <span>홈</span>
          <% end %>

          <%= link_to open_orders_masters_requests_path, class: "bottom-tab-item #{action_name == 'open_orders' ? 'active' : ''}" do %>
            <svg class="w-6 h-6" fill="<%= action_name == 'open_orders' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
            <span>공개오더</span>
          <% end %>

          <%= link_to masters_requests_path, class: "bottom-tab-item #{controller_name == 'requests' && action_name == 'index' ? 'active' : ''}" do %>
            <svg class="w-6 h-6" fill="<%= controller_name == 'requests' && action_name == 'index' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"/>
            </svg>
            <span>내오더</span>
          <% end %>

          <%= link_to notifications_path, class: "bottom-tab-item #{controller_name == 'notifications' ? 'active' : ''}" do %>
            <svg class="w-6 h-6" fill="<%= controller_name == 'notifications' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"/>
            </svg>
            <span>알림</span>
          <% end %>

          <%= link_to masters_profile_path, class: "bottom-tab-item #{controller_name == 'profiles' ? 'active' : ''}" do %>
            <svg class="w-6 h-6" fill="<%= controller_name == 'profiles' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
            <span>마이</span>
          <% end %>

        <% elsif user_signed_in? && current_user.admin? %>
          <%# 어드민용은 하단 탭 없음 (데스크톱 중심) %>
        <% else %>
          <%# 비로그인 5탭: 홈 / AI진단 / 체크하기(+) / 로그인 / 더보기 %>
          <%= link_to root_path, class: "bottom-tab-item #{controller_name == 'pages' ? 'active' : ''}" do %>
            <svg class="w-6 h-6" fill="<%= controller_name == 'pages' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="<%= controller_name == 'pages' ? '0' : '1.5' %>" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
            </svg>
            <span>홈</span>
          <% end %>

          <%= link_to new_leak_inspection_path, class: "bottom-tab-item #{controller_name == 'leak_inspections' ? 'active' : ''}" do %>
            <svg class="w-6 h-6" fill="<%= controller_name == 'leak_inspections' ? 'currentColor' : 'none' %>" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
            </svg>
            <span>AI진단</span>
          <% end %>

          <%= link_to new_customers_request_path, class: "bottom-tab-item", data: { turbo: false } do %>
            <div class="w-10 h-10 -mt-4 bg-primary-600 rounded-full flex items-center justify-center shadow-lg">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4"/>
              </svg>
            </div>
            <span class="-mt-1 text-primary-600 font-semibold">체크</span>
          <% end %>

          <%= link_to new_user_session_path, class: "bottom-tab-item #{controller_name == 'sessions' ? 'active' : ''}" do %>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
            </svg>
            <span>로그인</span>
          <% end %>

          <%= link_to about_path, class: "bottom-tab-item #{controller_name == 'pages' && action_name == 'about' ? 'active' : ''}" do %>
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6h16M4 12h16M4 18h16"/>
            </svg>
            <span>더보기</span>
          <% end %>
        <% end %>
      </div>
    </nav>

    <!-- 하단 탭 높이만큼 여백 추가 (모바일) -->
    <% unless user_signed_in? && current_user&.admin? %>
      <div class="md:hidden h-14"></div>
    <% end %>
  <% end %>

  <!-- Footer (데스크톱 전용, 네이티브 앱에서는 숨김) -->
  <% unless hotwire_native_app? %>
  <footer class="hidden md:block bg-gray-50 border-t border-gray-100 py-8 mt-auto">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mb-6">
        <div>
          <h3 class="text-gray-900 font-bold text-lg mb-3">누수체크</h3>
          <p class="text-sm text-gray-500">누수 전문 매칭 플랫폼</p>
          <p class="text-sm text-gray-500">투명한 가격, 검증된 전문가</p>
        </div>
        <div>
          <h3 class="text-gray-900 font-semibold text-sm mb-3">서비스</h3>
          <ul class="space-y-2 text-sm">
            <li><%= link_to "AI 진단", new_leak_inspection_path, class: "text-gray-500 hover:text-gray-900 transition" %></li>
            <li><%= link_to "서비스 소개", about_path, class: "text-gray-500 hover:text-gray-900 transition" %></li>
            <li><%= link_to "가격안내", pricing_path, class: "text-gray-500 hover:text-gray-900 transition" %></li>
          </ul>
        </div>
        <div>
          <h3 class="text-gray-900 font-semibold text-sm mb-3">고객지원</h3>
          <ul class="space-y-2 text-sm">
            <li><%= link_to "의견 보내기", new_feedback_path, class: "text-gray-500 hover:text-gray-900 transition" %></li>
            <li><%= link_to "설문 참여하기", new_survey_path, class: "text-gray-500 hover:text-gray-900 transition" %></li>
            <li><a href="mailto:contact@nusucheck.com" class="text-gray-500 hover:text-gray-900 transition">contact@nusucheck.com</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-gray-200 pt-6 text-center">
        <p class="text-sm text-gray-400">&copy; <%= Date.current.year %> 누수체크. All rights reserved.</p>
      </div>
    </div>
  </footer>
  <% end %>

  <% unless hotwire_native_app? %>
  <script>
    if ("serviceWorker" in navigator) {
      navigator.serviceWorker.register("/service-worker.js")
    }
  </script>
  <% end %>
</body>
</html>

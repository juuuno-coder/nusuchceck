<%# 게시글 상세 %>
<% content_for :title, @post.title %>

<div class="max-w-2xl mx-auto px-4 pb-24">

  <!-- 헤더 내비 -->
  <div class="flex items-center gap-2 pt-4 pb-3">
    <%= link_to community_path, class: "w-9 h-9 flex items-center justify-center rounded-full hover:bg-gray-100 transition -ml-2 flex-shrink-0" do %>
      <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
    <% end %>
    <span class="text-sm font-semibold text-gray-700">커뮤니티</span>
  </div>

  <!-- 본문 카드 -->
  <div class="bg-white rounded-2xl border border-gray-100 shadow-sm overflow-hidden">

    <!-- 이미지 (있을 때) -->
    <% if @post.image.attached? %>
      <div class="aspect-video bg-gray-100">
        <%= image_tag @post.image, class: "w-full h-full object-cover", alt: @post.title %>
      </div>
    <% end %>

    <div class="p-5">
      <!-- 카테고리 + 날짜 -->
      <div class="flex items-center justify-between mb-3">
        <span class="text-[11px] font-bold px-2.5 py-1 rounded-full <%= @post.category_color %>">
          <%= @post.category_label %>
        </span>
        <span class="text-xs text-gray-400"><%= @post.created_at.strftime("%Y.%m.%d %H:%M") %></span>
      </div>

      <!-- 제목 -->
      <h1 class="text-xl font-bold text-gray-900 leading-snug mb-4">
        <%= @post.title %>
      </h1>

      <!-- 작성자 -->
      <div class="flex items-center gap-2.5 pb-4 border-b border-gray-100 mb-5">
        <div class="w-9 h-9 bg-gradient-to-br from-primary-400 to-teal-500 rounded-full flex items-center justify-center text-white text-sm font-bold flex-shrink-0">
          <%= @post.user.name&.first || "?" %>
        </div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold text-gray-800 leading-none">
            <%= @post.user.name&.first&.then { |c| "#{c}*" } || "익명" %>
          </p>
          <p class="text-xs text-gray-400 mt-0.5"><%= time_ago_in_words(@post.created_at) %> 전</p>
        </div>
        <div class="flex items-center gap-1 text-xs text-gray-400">
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0zM2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
          </svg>
          <span><%= @post.views_count %></span>
        </div>
      </div>

      <!-- 본문 -->
      <div class="text-gray-700 text-[15px] leading-relaxed whitespace-pre-wrap min-h-[80px]">
        <%= @post.content %>
      </div>
    </div>
  </div>

  <!-- 수정/삭제 -->
  <% if user_signed_in? && (@post.user == current_user || current_user.admin?) %>
    <div class="flex justify-end gap-1 mt-3">
      <%= link_to edit_post_path(@post), class: "px-3 py-1.5 text-xs font-medium text-gray-500 hover:text-gray-800 hover:bg-gray-100 rounded-lg transition" do %>
        수정
      <% end %>
      <%= button_to post_path(@post), method: :delete,
            form: { data: { turbo_confirm: "정말 삭제할까요?" }, class: "inline" },
            class: "px-3 py-1.5 text-xs font-medium text-red-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition" do %>
        삭제
      <% end %>
    </div>
  <% end %>

  <!-- 댓글 섹션 -->
  <div class="mt-5" id="comments">
    <div class="flex items-center gap-2 mb-3">
      <h2 class="text-sm font-bold text-gray-800">댓글</h2>
      <span class="text-xs font-semibold text-primary-600 bg-primary-50 px-2 py-0.5 rounded-full">
        <%= @comments.sum { |c| 1 + c.replies.size } %>
      </span>
    </div>

    <!-- 댓글 목록 -->
    <% if @comments.any? %>
      <div class="space-y-1 mb-4">
        <% @comments.each do |comment| %>
          <%= render "comments/comment", comment: comment, post: @post %>
        <% end %>
      </div>
    <% end %>

    <!-- 댓글 작성 폼 -->
    <% if user_signed_in? %>
      <div class="bg-white rounded-2xl border border-gray-100 p-4">
        <%= form_with model: [@post, @comment], local: true do |f| %>
          <%= f.hidden_field :parent_id, value: nil %>
          <div class="flex gap-3">
            <div class="w-8 h-8 bg-gradient-to-br from-primary-400 to-teal-500 rounded-full flex items-center justify-center text-white text-xs font-bold flex-shrink-0 mt-0.5">
              <%= current_user.name&.first || "?" %>
            </div>
            <div class="flex-1">
              <%= f.text_area :content, rows: 2,
                    placeholder: "댓글을 남겨보세요",
                    class: "w-full text-sm text-gray-800 placeholder-gray-400 bg-gray-50 border border-gray-200 rounded-xl px-3 py-2.5 focus:outline-none focus:ring-2 focus:ring-primary-300 focus:bg-white resize-none transition" %>
              <div class="flex justify-end mt-2">
                <%= f.submit "등록", class: "px-4 py-1.5 bg-primary-600 text-white text-sm font-semibold rounded-xl hover:bg-primary-700 transition cursor-pointer" %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="bg-gray-50 rounded-2xl p-4 text-center">
        <p class="text-sm text-gray-500">
          <%= link_to "로그인", new_user_session_path, class: "text-primary-600 font-semibold" %>하면 댓글을 남길 수 있어요
        </p>
      </div>
    <% end %>
  </div>

  <!-- 다른 글 목록 -->
  <% if @other_posts.any? %>
    <div class="mt-6">
      <div class="flex items-center justify-between mb-3">
        <h3 class="text-sm font-bold text-gray-800">다른 글 보기</h3>
        <%= link_to community_path, class: "text-xs text-primary-600 font-semibold hover:text-primary-700 transition" do %>
          전체 보기 →
        <% end %>
      </div>
      <div class="bg-white rounded-2xl border border-gray-100 shadow-sm divide-y divide-gray-50 overflow-hidden">
        <% @other_posts.each do |p| %>
          <%= link_to post_path(p), class: "flex items-center gap-3 px-4 py-3 hover:bg-gray-50 transition-colors group" do %>
            <!-- 아이콘 -->
            <% post_icons = {"tip" => "tip", "review" => "star", "question" => "inspect", "general" => "document"} %>
            <div class="w-9 h-9 rounded-xl bg-primary-50 flex items-center justify-center flex-shrink-0">
              <img src="/images/icons/<%= post_icons[p.category] || "document" %>.png" alt="" class="w-6 h-6 object-contain mix-blend-multiply">
            </div>
            <!-- 텍스트 -->
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-1.5 mb-0.5">
                <span class="text-[10px] font-semibold px-1.5 py-0.5 rounded-full <%= p.category_color %>">
                  <%= p.category_label %>
                </span>
              </div>
              <p class="text-sm font-medium text-gray-800 truncate group-hover:text-primary-600 transition-colors">
                <%= p.title %>
              </p>
            </div>
            <!-- 날짜 -->
            <span class="text-[11px] text-gray-400 flex-shrink-0"><%= time_ago_in_words(p.created_at) %> 전</span>
          <% end %>
        <% end %>
      </div>
    </div>
  <% end %>

</div>

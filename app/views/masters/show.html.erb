<% content_for :title, "#{@master.name} 전문가 프로필" %>

<%# 신뢰도 온도 제거됨 %>

<div class="max-w-lg mx-auto pb-24 px-4">

  <!-- 뒤로가기 -->
  <div class="py-4">
    <%= link_to :back, class: "inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-700" do %>
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
      </svg>
      돌아가기
    <% end %>
  </div>

  <!-- Hero 카드 -->
  <div class="bg-gradient-to-br from-primary-50 to-blue-50 rounded-3xl p-6 mb-4">

    <!-- 아바타 + 이름 -->
    <div class="flex items-start gap-4 mb-4">
      <div class="w-20 h-20 rounded-2xl flex-shrink-0 shadow-md overflow-hidden">
        <% if @profile&.profile_photo&.attached? %>
          <%= image_tag @profile.profile_photo.variant(resize_to_fill: [80, 80]), class: "w-full h-full object-cover" %>
        <% else %>
          <div class="w-full h-full bg-gradient-to-br from-primary-500 to-primary-700 flex items-center justify-center">
            <span class="text-white font-bold text-3xl"><%= @master.name&.first %></span>
          </div>
        <% end %>
      </div>

      <div class="flex-1 min-w-0 pt-1">
        <div class="flex items-center gap-2 flex-wrap mb-2">
          <h1 class="text-xl font-bold text-gray-900"><%= @master.name %></h1>
          <% if @profile&.verified? %>
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 bg-primary-600 text-white text-xs font-bold rounded-full">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              인증 전문가
            </span>
          <% end %>
          <% if @profile&.insurance_active? %>
            <span class="inline-flex items-center gap-1 px-2.5 py-0.5 bg-green-100 text-green-700 text-xs font-bold rounded-full">
              <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M2.166 4.999A11.954 11.954 0 0010 1.944 11.954 11.954 0 0017.834 5c.11.65.166 1.32.166 2.001 0 5.225-3.34 9.67-8 11.317C5.34 16.67 2 12.225 2 7c0-.682.057-1.35.166-2.001zm11.541 3.708a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
              </svg>
              보험 인증
            </span>
          <% end %>
        </div>

        <!-- 스탯 칩 -->
        <div class="flex items-center gap-2 flex-wrap">
          <% if @avg_rating > 0 %>
            <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-white rounded-full shadow-sm text-xs font-semibold text-gray-700">
              <svg class="w-3.5 h-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
              </svg>
              <%= @avg_rating %> (<%= @review_count %>)
            </span>
          <% end %>
          <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-white rounded-full shadow-sm text-xs font-semibold text-gray-700">
            <svg class="w-3.5 h-3.5 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            완료 <%= @completed_count %>건
          </span>
          <% if @profile&.experience_years.to_i > 0 %>
            <span class="inline-flex items-center gap-1 px-2.5 py-1 bg-white rounded-full shadow-sm text-xs font-semibold text-gray-700">
              <svg class="w-3.5 h-3.5 text-primary-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 13.255A23.931 23.931 0 0112 15c-3.183 0-6.22-.62-9-1.745M16 6V4a2 2 0 00-2-2h-4a2 2 0 00-2 2v2m4 6h.01M5 20h14a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              경력 <%= @profile.experience_years %>년
            </span>
          <% end %>
        </div>
      </div>
    </div>

    <!-- 한 줄 소개 -->
    <% if @profile&.tagline.present? %>
      <p class="text-sm font-semibold text-primary-700 mb-2"><%= @profile.tagline %></p>
    <% end %>

    <!-- 소개글 -->
    <% if @profile&.bio.present? %>
      <p class="text-sm text-gray-600 leading-relaxed mb-4"><%= @profile.bio %></p>
    <% end %>

    <!-- 통계 요약 -->
    <div class="flex gap-2 mt-2">
      <div class="flex-1 bg-white/60 rounded-xl px-3 py-2 text-center">
        <p class="text-lg font-bold text-primary-600"><%= @completed_count %></p>
        <p class="text-[10px] text-gray-500">완료 작업</p>
      </div>
      <div class="flex-1 bg-white/60 rounded-xl px-3 py-2 text-center">
        <p class="text-lg font-bold text-amber-500"><%= @avg_rating > 0 ? @avg_rating : "-" %></p>
        <p class="text-[10px] text-gray-500">평점</p>
      </div>
      <div class="flex-1 bg-white/60 rounded-xl px-3 py-2 text-center">
        <p class="text-lg font-bold text-green-600"><%= @review_count %></p>
        <p class="text-[10px] text-gray-500">리뷰</p>
      </div>
    </div>
  </div>

  <!-- CTA 버튼 -->
  <% if user_signed_in? && current_user.customer? %>
    <div class="flex gap-3 mb-4">
      <%= link_to new_customers_request_path, class: "flex-1 py-3.5 text-center font-bold rounded-2xl bg-primary-600 text-white hover:bg-primary-700 transition-colors text-sm", data: { turbo: false } do %>
        체크 의뢰하기
      <% end %>
      <% if @request_with_master.present? %>
        <%= link_to request_messages_path(@request_with_master), class: "flex-1 py-3.5 text-center font-bold rounded-2xl bg-white border-2 border-primary-600 text-primary-700 hover:bg-primary-50 transition-colors text-sm" do %>
          채팅하기
        <% end %>
      <% end %>
    </div>
  <% end %>

  <!-- 전문 분야 -->
  <% if @profile&.specialty_types_list.any? %>
    <div class="bg-white rounded-2xl border border-gray-100 p-5 mb-4">
      <h2 class="text-sm font-bold text-gray-700 mb-3">전문 분야</h2>
      <div class="flex flex-wrap gap-2">
        <% @profile.specialty_types_list.each do |specialty| %>
          <span class="px-3 py-1.5 bg-primary-50 text-primary-700 text-sm font-semibold rounded-full"><%= specialty %></span>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- 서비스 지역 + 보유 장비 -->
  <% if @profile&.service_areas_list.any? || @profile&.equipment_list.any? %>
    <div class="bg-white rounded-2xl border border-gray-100 p-5 mb-4 space-y-4">
      <% if @profile&.service_areas_list.any? %>
        <div>
          <h2 class="text-sm font-bold text-gray-700 mb-2">서비스 지역</h2>
          <div class="flex flex-wrap gap-2">
            <% @profile.service_areas_list.each do |area| %>
              <span class="flex items-center gap-1 px-3 py-1 bg-gray-50 text-gray-600 text-sm rounded-full border border-gray-100">
                <svg class="w-3.5 h-3.5 text-primary-400" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M5.05 4.05a7 7 0 119.9 9.9L10 18.9l-4.95-4.95a7 7 0 010-9.9zM10 11a2 2 0 100-4 2 2 0 000 4z" clip-rule="evenodd"/>
                </svg>
                <%= area %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>

      <% if @profile&.equipment_list.any? %>
        <div>
          <h2 class="text-sm font-bold text-gray-700 mb-2">보유 장비</h2>
          <div class="flex flex-wrap gap-2">
            <% @profile.equipment_list.each do |eq| %>
              <span class="flex items-center gap-1.5 px-3 py-1 bg-gray-50 text-gray-600 text-sm rounded-full border border-gray-100">
                <span class="w-1.5 h-1.5 bg-primary-400 rounded-full"></span>
                <%= eq %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <!-- 자격증 -->
  <% if @profile&.certifications_list.any? %>
    <div class="bg-white rounded-2xl border border-gray-100 p-5 mb-4">
      <h2 class="text-sm font-bold text-gray-700 mb-3">자격증 / 수료증</h2>
      <div class="flex flex-wrap gap-2">
        <% @profile.certifications_list.each do |cert| %>
          <span class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-amber-50 text-amber-800 text-xs font-semibold rounded-full border border-amber-100">
            <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
              <path d="M10.394 2.08a1 1 0 00-.788 0l-7 3a1 1 0 000 1.84L5.25 8.051a.999.999 0 01.356-.257l4-1.714a1 1 0 11.788 1.838L7.667 9.088l1.94.831a1 1 0 00.787 0l7-3a1 1 0 000-1.838l-7-3zM3.31 9.397L5 10.12v4.102a8.969 8.969 0 00-1.05-.174 1 1 0 01-.89-.89 11.115 11.115 0 01.25-3.762zM9.3 16.573A9.026 9.026 0 007 14.935v-3.957l1.818.78a3 3 0 002.364 0l5.508-2.361a11.026 11.026 0 01.25 3.762 1 1 0 01-.89.89 8.968 8.968 0 00-5.35 2.524 1 1 0 01-1.4 0zM6 18a1 1 0 001-1v-2.065a8.935 8.935 0 00-2-.712V17a1 1 0 001 1z"/>
            </svg>
            <%= cert %>
          </span>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- 시공 사례 사진 -->
  <% if @profile&.work_photos&.attached? %>
    <div class="bg-white rounded-2xl border border-gray-100 p-5 mb-4">
      <h2 class="text-sm font-bold text-gray-700 mb-3">시공 사례</h2>
      <div class="grid grid-cols-2 gap-2">
        <% @profile.work_photos.each do |photo| %>
          <%= image_tag photo.variant(resize_to_fill: [300, 200]), class: "w-full h-32 object-cover rounded-xl" %>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- 소개 영상 -->
  <% if @profile&.intro_video_url.present? %>
    <%
      video_id = @profile.intro_video_url.match(/(?:v=|youtu\.be\/)([A-Za-z0-9_-]{11})/i)&.[](1)
    %>
    <% if video_id %>
      <div class="bg-white rounded-2xl border border-gray-100 p-5 mb-4">
        <h2 class="text-sm font-bold text-gray-700 mb-3">소개 영상</h2>
        <div class="aspect-video rounded-xl overflow-hidden">
          <iframe src="https://www.youtube.com/embed/<%= video_id %>"
                  class="w-full h-full" frameborder="0" allowfullscreen
                  title="<%= @master.name %> 소개 영상"></iframe>
        </div>
      </div>
    <% end %>
  <% end %>

  <!-- 커스텀 링크 -->
  <% if @profile&.parsed_links.any? %>
    <div class="bg-white rounded-2xl border border-gray-100 p-5 mb-4">
      <h2 class="text-sm font-bold text-gray-700 mb-3">링크</h2>
      <div class="space-y-2">
        <% @profile.parsed_links.each do |link| %>
          <%
            link_type = MasterProfile.detect_link_type(link[:url])
            link_colors = {
              "instagram" => "bg-gradient-to-r from-purple-500 to-pink-500",
              "youtube" => "bg-red-500",
              "naver_blog" => "bg-green-500",
              "tiktok" => "bg-gray-900",
              "facebook" => "bg-blue-600",
              "twitter" => "bg-gray-800",
              "kakao" => "bg-yellow-400",
              "website" => "bg-primary-500"
            }
          %>
          <a href="<%= link[:url] %>" target="_blank" rel="noopener"
             class="flex items-center gap-3 p-3 rounded-xl border border-gray-100 hover:border-gray-200 hover:shadow-sm transition-all group">
            <div class="w-9 h-9 rounded-lg <%= link_colors[link_type] || 'bg-gray-400' %> flex items-center justify-center flex-shrink-0">
              <span class="text-white text-xs font-bold"><%= (link[:title] || link_type).first(2).upcase %></span>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm font-semibold text-gray-900 truncate"><%= link[:title].presence || link[:url] %></p>
              <p class="text-xs text-gray-400 truncate"><%= URI.parse(link[:url]).host rescue link[:url] %></p>
            </div>
            <svg class="w-4 h-4 text-gray-300 group-hover:text-gray-500 transition flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- 인스타그램 포트폴리오 -->
  <% if @profile&.instagram_username.present? %>
    <% instagram_posts = @profile.instagram_posts.is_a?(Array) ? @profile.instagram_posts : [] %>
    <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden mb-4">
      <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
        <div class="flex items-center gap-2">
          <div class="w-6 h-6 rounded-md bg-gradient-to-br from-purple-500 via-pink-500 to-orange-400 flex items-center justify-center">
            <svg class="w-3.5 h-3.5 text-white" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </div>
          <h2 class="text-sm font-bold text-gray-700">시공 사례</h2>
        </div>
        <a href="https://instagram.com/<%= @profile.instagram_username %>" target="_blank" rel="noopener"
           class="text-xs text-gray-400 hover:text-gray-600 font-medium transition">@<%= @profile.instagram_username %></a>
      </div>

      <% if instagram_posts.any? %>
        <!-- 인스타 피드 그리드 -->
        <div class="grid grid-cols-3 gap-px bg-gray-100">
          <% instagram_posts.first(9).each do |post| %>
            <a href="<%= post["permalink"] || "https://instagram.com/#{@profile.instagram_username}" %>"
               target="_blank" rel="noopener" class="block aspect-square overflow-hidden bg-gray-200 hover:opacity-90 transition">
              <img src="<%= post["media_url"] %>" alt="" class="w-full h-full object-cover" loading="lazy">
            </a>
          <% end %>
        </div>
      <% else %>
        <!-- 연동 전 안내 + 시공 사진 갤러리 폴백 -->
        <% if @profile&.work_photos&.attached? %>
          <div class="grid grid-cols-3 gap-px bg-gray-100">
            <% @profile.work_photos.first(9).each do |photo| %>
              <div class="aspect-square overflow-hidden bg-gray-200">
                <%= image_tag photo.variant(resize_to_fill: [300, 300]), class: "w-full h-full object-cover", loading: "lazy" %>
              </div>
            <% end %>
          </div>
        <% else %>
          <div class="px-5 py-8 text-center">
            <img src="/images/characters/upload.png" alt="" class="w-16 h-16 mx-auto mb-3 object-contain opacity-60">
            <p class="text-sm text-gray-500">아직 시공 사례가 없어요</p>
            <p class="text-xs text-gray-400 mt-1">인스타그램을 연동하면 포트폴리오가 자동으로 표시돼요</p>
          </div>
        <% end %>
      <% end %>

      <!-- 인스타 바로가기 -->
      <a href="https://instagram.com/<%= @profile.instagram_username %>" target="_blank" rel="noopener"
         class="block px-5 py-3 border-t border-gray-100 text-center text-sm font-semibold text-primary-600 hover:bg-gray-50 transition">
        인스타그램에서 더 보기
      </a>
    </div>
  <% end %>

  <!-- 고객 리뷰 -->
  <div class="bg-white rounded-2xl border border-gray-100">
    <div class="px-5 py-4 border-b border-gray-100 flex items-center justify-between">
      <h2 class="text-base font-bold text-gray-900">고객 리뷰</h2>
      <% if @review_count > 0 %>
        <span class="text-sm text-gray-400"><%= @review_count %>개</span>
      <% end %>
    </div>

    <% if @reviews.any? %>
      <div class="divide-y divide-gray-50">
        <% @reviews.each do |review| %>
          <div class="p-5">
            <div class="flex items-start gap-3">
              <%
                reviewer_name = review.customer&.name.to_s
                masked_name = if reviewer_name.length >= 3
                  reviewer_name[0] + '*' * (reviewer_name.length - 2) + reviewer_name[-1]
                elsif reviewer_name.length == 2
                  reviewer_name[0] + '*'
                else
                  reviewer_name[0].to_s
                end
              %>
              <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center text-xs font-bold text-gray-600 flex-shrink-0">
                <%= reviewer_name.first %>
              </div>

              <div class="flex-1 min-w-0">
                <div class="flex items-center justify-between mb-1">
                  <div class="flex items-center gap-2">
                    <span class="text-sm font-semibold text-gray-900"><%= masked_name %></span>
                    <div class="flex">
                      <% 5.times do |i| %>
                        <svg class="w-3.5 h-3.5 <%= i < review.rating ? 'text-yellow-400' : 'text-gray-200' %>" fill="currentColor" viewBox="0 0 20 20">
                          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                        </svg>
                      <% end %>
                    </div>
                  </div>
                  <span class="text-xs text-gray-400 flex-shrink-0"><%= review.created_at.strftime("%y.%m.%d") %></span>
                </div>

                <% if review.comment.present? %>
                  <p class="text-sm text-gray-700 leading-relaxed"><%= review.comment %></p>
                <% end %>
                <% if review.request&.address.present? %>
                  <p class="text-xs text-gray-400 mt-1.5">
                    <%= review.request.address&.truncate(20) %>
                    <% if review.request.symptom_type.present? %>
                      · <%= symptom_label(review.request.symptom_type) %>
                    <% end %>
                  </p>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="py-12 text-center">
        <svg class="w-10 h-10 mx-auto text-gray-200 mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
        </svg>

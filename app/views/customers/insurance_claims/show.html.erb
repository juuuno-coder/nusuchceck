<%# 보험 청구서 상세 %>
<div class="max-w-2xl mx-auto px-4 py-8">

  <%# 뒤로가기 %>
  <%= link_to customers_insurance_claims_path, class: "inline-flex items-center gap-1.5 text-sm text-gray-500 hover:text-gray-800 mb-6 transition-colors" do %>
    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
    목록으로
  <% end %>

  <%# 헤더 %>
  <div class="mb-8">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-2xl font-bold text-gray-900 mb-1">보험 청구서</h1>
        <p class="text-sm text-gray-400 font-mono"><%= @insurance_claim.claim_number %></p>
      </div>
      <span class="flex-shrink-0 mt-1 px-3 py-1 rounded-full text-xs font-semibold
        <%= case @insurance_claim.status
            when 'draft' then 'bg-gray-100 text-gray-600'
            when 'pending_customer_review' then 'bg-amber-100 text-amber-700'
            when 'submitted' then 'bg-blue-100 text-blue-700'
            when 'under_review' then 'bg-yellow-100 text-yellow-700'
            when 'approved' then 'bg-green-100 text-green-700'
            when 'rejected' then 'bg-red-100 text-red-700'
            when 'completed' then 'bg-purple-100 text-purple-700'
            end %>">
        <%= @insurance_claim.status_label %>
      </span>
    </div>

    <%# 전문가 작성 배지 %>
    <% if @insurance_claim.prepared_by_master? %>
      <div class="mt-4 inline-flex items-center gap-2 px-3 py-1.5 bg-purple-50 border border-purple-100 rounded-lg">
        <svg class="w-3.5 h-3.5 text-purple-500" fill="currentColor" viewBox="0 0 20 20">
          <path fill-rule="evenodd" d="M6.267 3.455a3.066 3.066 0 001.745-.723 3.066 3.066 0 013.976 0 3.066 3.066 0 001.745.723 3.066 3.066 0 012.812 2.812c.051.643.304 1.254.723 1.745a3.066 3.066 0 010 3.976 3.066 3.066 0 00-.723 1.745 3.066 3.066 0 01-2.812 2.812 3.066 3.066 0 00-1.745.723 3.066 3.066 0 01-3.976 0 3.066 3.066 0 00-1.745-.723 3.066 3.066 0 01-2.812-2.812 3.066 3.066 0 00-.723-1.745 3.066 3.066 0 010-3.976 3.066 3.066 0 00.723-1.745 3.066 3.066 0 012.812-2.812zm7.44 5.252a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
        </svg>
        <span class="text-xs font-medium text-purple-700">전문가 작성 · <%= @insurance_claim.prepared_by_master.name %></span>
        <% if @insurance_claim.customer_reviewed? %>
          <span class="text-xs text-purple-400">· 승인됨</span>
        <% end %>
      </div>
    <% end %>
  </div>

  <%# 진행 상태 스텝퍼 %>
  <% steps = [
    { keys: %w[draft pending_customer_review], label: "작성중" },
    { keys: %w[submitted], label: "작성완료" },
    { keys: %w[under_review], label: "제출완료" },
    { keys: %w[approved rejected completed], label: "심사완료" }
  ]
  current_step = steps.index { |s| s[:keys].include?(@insurance_claim.status) } || 0
  %>
  <div class="mb-8 bg-white border border-gray-100 rounded-2xl px-6 py-5">
    <div class="flex items-center">
      <% steps.each_with_index do |step, i| %>
        <% done = i < current_step %>
        <% active = i == current_step %>

        <div class="flex flex-col items-center">
          <div class="w-8 h-8 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0
            <%= done ? 'bg-primary-600 text-white' : active ? 'bg-primary-600 text-white ring-4 ring-primary-100' : 'bg-gray-100 text-gray-400' %>">
            <% if done %>
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
            <% else %>
              <%= i + 1 %>
            <% end %>
          </div>
          <span class="mt-2 text-[10px] font-medium whitespace-nowrap
            <%= active ? 'text-primary-700' : done ? 'text-gray-500' : 'text-gray-300' %>">
            <%= step[:label] %>
          </span>
        </div>

        <% if i < steps.length - 1 %>
          <div class="flex-1 h-0.5 mx-1.5 mb-5 <%= i < current_step ? 'bg-primary-600' : 'bg-gray-100' %>"></div>
        <% end %>
      <% end %>
    </div>
  </div>

  <%# 상태별 안내 배너 %>
  <% case @insurance_claim.status %>
  <% when 'pending_customer_review' %>
    <div class="mb-6 border border-amber-200 bg-amber-50 rounded-2xl p-5">
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 bg-amber-400 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
          </svg>
        </div>
        <div>
          <p class="font-semibold text-amber-900 text-sm mb-0.5">전문가가 작성한 청구서를 검토해주세요</p>
          <p class="text-amber-800 text-xs">내용을 확인하신 후 승인하시면 자동으로 보험사에 접수됩니다. 승인 후에는 수정이 불가합니다.</p>
        </div>
      </div>
    </div>

  <% when 'draft' %>
    <div class="mb-6 border border-gray-200 bg-gray-50 rounded-2xl p-5">
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 bg-gray-300 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"/>
          </svg>
        </div>
        <div>
          <p class="font-semibold text-gray-800 text-sm mb-0.5">임시저장 상태입니다</p>
          <p class="text-gray-600 text-xs">내용을 확인하신 후 제출하시면 보험사로 접수됩니다. 제출 전까지 수정 가능합니다.</p>
        </div>
      </div>
    </div>

  <% when 'submitted' %>
    <div class="mb-6 border border-blue-200 bg-blue-50 rounded-2xl p-5">
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 bg-blue-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
          </svg>
        </div>
        <div class="flex-1">
          <p class="font-semibold text-blue-900 text-sm mb-1">청구서가 준비되었습니다</p>
          <p class="text-blue-800 text-xs mb-3">PDF를 다운로드하여 보험사에 직접 제출해주세요.</p>
          <div class="flex flex-col sm:flex-row gap-2">
            <%= link_to download_pdf_customers_insurance_claim_path(@insurance_claim),
                        class: "inline-flex items-center justify-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm font-semibold rounded-lg hover:bg-blue-700 transition-colors" do %>
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
              청구서 PDF 다운로드
            <% end %>
            <button type="button" onclick="openInsuranceGuide()"
                    class="inline-flex items-center justify-center gap-2 px-4 py-2 bg-white text-blue-700 text-sm font-semibold rounded-lg border border-blue-200 hover:bg-blue-50 transition-colors">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-2 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
              </svg>
              보험사 안내
            </button>
          </div>
        </div>
      </div>
    </div>

  <% when 'under_review' %>
    <div class="mb-6 border border-yellow-200 bg-yellow-50 rounded-2xl p-5">
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 bg-yellow-400 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
        </div>
        <div>
          <p class="font-semibold text-yellow-900 text-sm mb-0.5">보험사 심사 중</p>
          <p class="text-yellow-800 text-xs">서류를 검토하고 있습니다. 평균 7~14일 소요되며, 결과는 문자 및 이메일로 안내됩니다.</p>
        </div>
      </div>
    </div>

  <% when 'approved' %>
    <div class="mb-6 border border-green-200 bg-green-50 rounded-2xl p-5">
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 bg-green-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div>
          <p class="font-semibold text-green-900 text-sm mb-0.5">심사 승인</p>
          <p class="text-green-800 text-xs">보험금 지급 절차가 진행됩니다. 등록하신 계좌로 입금 예정이며, 지급 완료 시 안내드립니다.</p>
        </div>
      </div>
    </div>

  <% when 'rejected' %>
    <div class="mb-6 border border-red-200 bg-red-50 rounded-2xl p-5">
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 bg-red-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </div>
        <div>
          <p class="font-semibold text-red-900 text-sm mb-0.5">심사 반려</p>
          <p class="text-red-800 text-xs">자세한 사유는 보험사로 문의하시기 바랍니다. 이의신청이 필요한 경우 보험사 고객센터에 문의해주세요.</p>
        </div>
      </div>
    </div>

  <% when 'completed' %>
    <div class="mb-6 border border-purple-200 bg-purple-50 rounded-2xl p-5">
      <div class="flex items-start gap-3">
        <div class="w-8 h-8 bg-purple-500 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
          <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
          </svg>
        </div>
        <div>
          <p class="font-semibold text-purple-900 text-sm mb-0.5">모든 절차 완료</p>
          <p class="text-purple-800 text-xs">보험금 지급이 완료되었습니다. 계좌를 확인해주세요.</p>
        </div>
      </div>
    </div>
  <% end %>

  <%# 정보 카드 %>
  <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden mb-6">

    <%# 신청자 정보 %>
    <div class="px-6 py-5">
      <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">신청자 정보</h3>
      <dl class="grid grid-cols-2 gap-x-6 gap-y-4 text-sm">
        <div>
          <dt class="text-gray-400 text-xs mb-1">성명</dt>
          <dd class="font-medium text-gray-900"><%= @insurance_claim.applicant_name %></dd>
        </div>
        <div>
          <dt class="text-gray-400 text-xs mb-1">연락처</dt>
          <dd class="font-medium text-gray-900"><%= @insurance_claim.applicant_phone %></dd>
        </div>
        <% if @insurance_claim.applicant_email.present? %>
          <div>
            <dt class="text-gray-400 text-xs mb-1">이메일</dt>
            <dd class="font-medium text-gray-900"><%= @insurance_claim.applicant_email %></dd>
          </div>
        <% end %>
        <% if @insurance_claim.birth_date.present? %>
          <div>
            <dt class="text-gray-400 text-xs mb-1">생년월일</dt>
            <dd class="font-medium text-gray-900"><%= @insurance_claim.birth_date.strftime("%Y.%m.%d") %></dd>
          </div>
        <% end %>
      </dl>
    </div>

    <div class="border-t border-gray-50"></div>

    <%# 사고 정보 %>
    <div class="px-6 py-5">
      <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">사고 정보</h3>
      <dl class="grid grid-cols-2 gap-x-6 gap-y-4 text-sm">
        <div>
          <dt class="text-gray-400 text-xs mb-1">사고 발생일</dt>
          <dd class="font-medium text-gray-900"><%= @insurance_claim.incident_date.strftime("%Y.%m.%d") %></dd>
        </div>
        <div>
          <dt class="text-gray-400 text-xs mb-1">피해 유형</dt>
          <dd class="font-medium text-gray-900"><%= @insurance_claim.damage_type_label %></dd>
        </div>
        <div class="col-span-2">
          <dt class="text-gray-400 text-xs mb-1">사고 장소</dt>
          <dd class="font-medium text-gray-900">
            <%= @insurance_claim.incident_address %>
            <% if @insurance_claim.incident_detail_address.present? %>
              <span class="text-gray-500"> <%= @insurance_claim.incident_detail_address %></span>
            <% end %>
          </dd>
        </div>
        <% if @insurance_claim.estimated_damage_amount.present? %>
          <div>
            <dt class="text-gray-400 text-xs mb-1">예상 피해 금액</dt>
            <dd class="font-medium text-gray-900"><%= number_to_currency(@insurance_claim.estimated_damage_amount, unit: "₩", precision: 0) %></dd>
          </div>
        <% end %>
        <div class="col-span-2">
          <dt class="text-gray-400 text-xs mb-1">사고 내용</dt>
          <dd class="text-gray-800 text-sm leading-relaxed whitespace-pre-line mt-1 bg-gray-50 rounded-xl p-3"><%= @insurance_claim.incident_description %></dd>
        </div>
      </dl>
    </div>

    <%# 보험 정보 %>
    <% if @insurance_claim.insurance_company.present? || @insurance_claim.policy_number.present? %>
      <div class="border-t border-gray-50"></div>
      <div class="px-6 py-5">
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">보험 정보</h3>
        <dl class="grid grid-cols-2 gap-x-6 gap-y-4 text-sm">
          <div>
            <dt class="text-gray-400 text-xs mb-1">보험사</dt>
            <dd class="font-medium text-gray-900"><%= @insurance_claim.insurance_company || "-" %></dd>
          </div>
          <div>
            <dt class="text-gray-400 text-xs mb-1">증권번호</dt>
            <dd class="font-medium text-gray-900"><%= @insurance_claim.policy_number || "-" %></dd>
          </div>
        </dl>
      </div>
    <% end %>

    <%# 피해자 정보 %>
    <% if @insurance_claim.victim_name.present? %>
      <div class="border-t border-gray-50"></div>
      <div class="px-6 py-5">
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">피해자 정보</h3>
        <dl class="grid grid-cols-2 gap-x-6 gap-y-4 text-sm">
          <div>
            <dt class="text-gray-400 text-xs mb-1">성명</dt>
            <dd class="font-medium text-gray-900"><%= @insurance_claim.victim_name %></dd>
          </div>
          <div>
            <dt class="text-gray-400 text-xs mb-1">연락처</dt>
            <dd class="font-medium text-gray-900"><%= @insurance_claim.victim_phone || "-" %></dd>
          </div>
          <% if @insurance_claim.victim_address.present? %>
            <div class="col-span-2">
              <dt class="text-gray-400 text-xs mb-1">주소</dt>
              <dd class="font-medium text-gray-900"><%= @insurance_claim.victim_address %></dd>
            </div>
          <% end %>
        </dl>
      </div>
    <% end %>

    <%# 연관 체크 %>
    <% if @insurance_claim.request.present? %>
      <div class="border-t border-gray-50"></div>
      <div class="px-6 py-5">
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">연관 누수 체크</h3>
        <div class="flex items-center justify-between bg-gray-50 rounded-xl p-3.5">
          <div class="text-sm">
            <span class="font-mono text-gray-400 text-xs">NSC-<%= @insurance_claim.request.id.to_s.rjust(6, '0') %></span>
            <p class="font-medium text-gray-800 mt-0.5"><%= @insurance_claim.request.address.truncate(35) %></p>
          </div>
          <%= link_to "보기", request_messages_path(@insurance_claim.request),
                class: "text-xs font-semibold text-primary-600 hover:text-primary-800" %>
        </div>
      </div>
    <% end %>

    <%# 증빙 서류 %>
    <% if @insurance_claim.supporting_documents.attached? %>
      <div class="border-t border-gray-50"></div>
      <div class="px-6 py-5">
        <h3 class="text-xs font-semibold text-gray-400 uppercase tracking-wider mb-4">
          증빙 서류 <span class="font-normal text-gray-300 normal-case tracking-normal"><%= @insurance_claim.supporting_documents.count %>건</span>
        </h3>
        <div class="grid grid-cols-3 gap-2">
          <% @insurance_claim.supporting_documents.each do |doc| %>
            <% if doc.content_type.start_with?("image/") %>
              <button type="button" onclick="openLightbox('<%= rails_blob_url(doc) %>')"
                      class="rounded-xl overflow-hidden cursor-zoom-in hover:opacity-90 transition">
                <%= image_tag rails_blob_url(doc), class: "object-cover h-28 w-full" %>
              </button>
            <% else %>
              <a href="<%= rails_blob_url(doc, disposition: 'attachment') %>" target="_blank"
                 class="bg-gray-50 rounded-xl p-3 flex flex-col items-start gap-1.5 hover:bg-gray-100 transition border border-gray-100">
                <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z"/>
                </svg>
                <span class="text-xs text-gray-600 leading-tight break-all"><%= doc.filename %></span>
              </a>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <%# 액션 영역 %>
  <% if @insurance_claim.pending_customer_review? %>
    <div class="bg-white border border-gray-100 rounded-2xl p-6 mb-4">
      <p class="text-sm text-gray-600 mb-5 leading-relaxed">
        전문가가 작성한 내용을 검토하신 후 승인해주세요. 승인하면 PDF가 생성되고, 보험사 접수 안내를 받을 수 있어요.
      </p>
      <div class="flex flex-col gap-3">
        <%= button_to customer_approve_customers_insurance_claim_path(@insurance_claim),
              method: :post,
              class: "w-full py-3.5 bg-primary-600 text-white rounded-xl font-semibold text-sm hover:bg-primary-700 transition",
              data: { turbo_confirm: "보험청구서를 승인하시겠습니까?\n\n승인 후 PDF를 다운로드받고 보험사에 직접 접수하시면 돼요." } do %>
          승인하고 접수 서류 받기
        <% end %>

        <details class="border border-gray-100 rounded-xl overflow-hidden">
          <summary class="px-4 py-3 text-sm font-medium text-gray-600 cursor-pointer hover:bg-gray-50 transition list-none flex items-center justify-between">
            <span>수정 요청하기</span>
            <svg class="w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
            </svg>
          </summary>
          <%= form_with url: customer_request_changes_customers_insurance_claim_path(@insurance_claim), method: :post, class: "px-4 pb-4 pt-1 space-y-3 border-t border-gray-50" do |f| %>
            <label class="block text-xs text-gray-500 mb-1">수정이 필요한 내용을 작성해주세요</label>
            <%= text_area_tag :customer_review_notes, nil, rows: 4, required: true,
                  placeholder: "예: 공사 금액을 550,000원으로 수정해주세요",
                  class: "w-full px-3 py-2.5 border border-gray-200 rounded-lg text-sm focus:ring-2 focus:ring-primary-400 focus:outline-none resize-none" %>
            <%= button_tag type: :submit,
                  class: "w-full py-2.5 bg-gray-800 text-white text-sm font-semibold rounded-lg hover:bg-gray-900 transition" do %>
              수정 요청 보내기
            <% end %>
          <% end %>
        </details>
      </div>
    </div>

  <% elsif @insurance_claim.draft? && !@insurance_claim.prepared_by_master? %>
    <div class="flex gap-3">
      <%= link_to edit_customers_insurance_claim_path(@insurance_claim),
            class: "flex-1 py-3.5 bg-white border border-gray-200 text-gray-700 rounded-xl font-semibold text-sm text-center hover:bg-gray-50 transition" do %>
        수정하기
      <% end %>
      <%= link_to download_pdf_customers_insurance_claim_path(@insurance_claim),
            class: "flex-1 py-3.5 bg-primary-600 text-white rounded-xl font-semibold text-sm text-center hover:bg-primary-700 transition" do %>
        PDF 다운로드
      <% end %>
      <button type="button" onclick="openInsuranceGuide()"
              class="flex-1 py-3.5 bg-white border-2 border-primary-600 text-primary-700 rounded-xl font-semibold text-sm hover:bg-primary-50 transition">
        보험사 접수 방법 안내
      </button>
    </div>

  <% elsif @insurance_claim.submitted? %>
    <%# 심사 시작 버튼 %>
    <div class="bg-white border border-gray-100 rounded-2xl p-6">
      <p class="text-sm font-semibold text-gray-800 mb-1">보험사에 접수하셨나요?</p>
      <p class="text-xs text-gray-500 mb-4">PDF를 다운로드하고 보험사 앱에서 직접 접수해주세요. 접수 완료 후 아래 버튼을 눌러주세요.</p>
      <div class="flex gap-2 mb-4">
        <%= link_to download_pdf_customers_insurance_claim_path(@insurance_claim),
              class: "flex-1 py-2.5 bg-white border border-gray-200 text-gray-700 rounded-xl font-semibold text-sm text-center hover:bg-gray-50 transition" do %>
          PDF 다운로드
        <% end %>
        <button type="button" onclick="openInsuranceGuide()"
                class="flex-1 py-2.5 bg-white border border-primary-200 text-primary-600 rounded-xl font-semibold text-sm hover:bg-primary-50 transition">
          접수 방법 안내
        </button>
      </div>
      <%= button_to start_review_customers_insurance_claim_path(@insurance_claim),
                    method: :patch,
                    data: { confirm: "보험사 제출을 완료하셨습니까?" },
                    class: "w-full py-3.5 bg-primary-600 text-white font-semibold text-sm rounded-xl hover:bg-primary-700 transition",
                    form: { class: "w-full" } do %>
        심사 시작
      <% end %>
    </div>

  <% else %>
    <div class="flex justify-center">
      <%= link_to download_pdf_customers_insurance_claim_path(@insurance_claim),
            class: "inline-flex items-center gap-2 px-6 py-3 bg-white border border-gray-200 text-gray-700 rounded-xl font-semibold text-sm hover:bg-gray-50 transition" do %>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        PDF 다운로드
      <% end %>
    </div>
  <% end %>
</div>

<!-- 라이트박스 -->
<div id="lightbox-claim" class="hidden fixed inset-0 z-50 bg-black/90 flex items-center justify-center p-4" onclick="closeLightboxClaim()">
  <img id="lightbox-claim-img" src="" class="max-w-full max-h-full object-contain rounded-lg">
</div>

<!-- 보험사 청구 안내 모달 -->
<div id="insuranceGuideModal" class="hidden fixed inset-0 bg-black/60 z-50 flex items-center justify-center p-4" onclick="if(event.target === this) closeInsuranceGuide()">
  <div class="bg-white rounded-2xl max-w-2xl w-full max-h-[90vh] overflow-y-auto shadow-2xl">

    <!-- 모달 헤더 -->
    <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
      <div>
        <h2 class="text-xl font-bold text-gray-900">보험사 청구 안내</h2>
        <p class="text-xs text-gray-500 mt-0.5">아래 보험사에 직접 청구서를 제출하세요</p>
      </div>
      <button onclick="closeInsuranceGuide()" class="text-gray-400 hover:text-gray-600 transition-colors p-1">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div class="p-6 space-y-4">
      <!-- 접수 단계 안내 -->
      <div class="bg-primary-50 rounded-xl p-4 space-y-2">
        <p class="text-sm font-bold text-primary-800">이렇게 접수하세요</p>
        <div class="flex items-start gap-2.5">
          <span class="w-5 h-5 bg-primary-600 text-white rounded-full flex items-center justify-center text-[10px] font-bold flex-shrink-0">1</span>
          <p class="text-xs text-primary-700">위에서 <strong>PDF 다운로드</strong>를 눌러 청구서를 저장하세요</p>
        </div>
        <div class="flex items-start gap-2.5">
          <span class="w-5 h-5 bg-primary-600 text-white rounded-full flex items-center justify-center text-[10px] font-bold flex-shrink-0">2</span>
          <p class="text-xs text-primary-700">아래에서 <strong>내 보험사를 찾아</strong> 앱을 열거나 전화하세요</p>
        </div>
        <div class="flex items-start gap-2.5">
          <span class="w-5 h-5 bg-primary-600 text-white rounded-full flex items-center justify-center text-[10px] font-bold flex-shrink-0">3</span>
          <p class="text-xs text-primary-700">보험사 앱에서 <strong>사고 접수 > 파일 첨부</strong>에 PDF를 올려주세요</p>
        </div>
        <div class="flex items-start gap-2.5">
          <span class="w-5 h-5 bg-primary-600 text-white rounded-full flex items-center justify-center text-[10px] font-bold flex-shrink-0">4</span>
          <p class="text-xs text-primary-700">접수 완료 후 누수체크에서 <strong>"심사 시작" 버튼</strong>을 눌러주세요</p>
        </div>
      </div>

      <!-- 보험사별 카드 -->
      <% InsuranceSubmissionService.all_companies_guide.each do |company| %>
        <div class="border border-gray-200 rounded-xl overflow-hidden hover:border-gray-300 hover:shadow-sm transition-all">
          <div class="flex items-center gap-4 px-4 py-3.5">
            <!-- 이니셜 배지 -->
            <div class="w-10 h-10 rounded-lg <%= company[:badge_color] %> flex items-center justify-center flex-shrink-0">
              <span class="text-white text-sm font-bold"><%= company[:company_name].first(2) %></span>
            </div>

            <!-- 회사 정보 -->
            <div class="flex-1 min-w-0">
              <p class="font-semibold text-gray-900 text-sm"><%= company[:company_name] %></p>
              <div class="flex flex-wrap gap-x-4 gap-y-0.5 mt-1">
                <span class="text-xs text-gray-500">앱 · <%= company[:app_name] %></span>
                <span class="text-xs text-gray-500">대표전화 <%= company[:phone] %></span>
              </div>
            </div>

            <!-- 바로가기 -->
            <a href="<%= company[:website] %>" target="_blank" rel="noopener"
               class="flex-shrink-0 px-3 py-1.5 border border-gray-300 text-gray-700 rounded-lg text-xs font-medium hover:bg-gray-50 transition-colors">
              홈페이지
            </a>
          </div>
        </div>
      <% end %>

      <!-- 제출 시 유의사항 -->
      <div class="mt-2 p-4 bg-gray-50 rounded-xl border border-gray-200">
        <h4 class="text-sm font-semibold text-gray-800 mb-3">제출 시 유의사항</h4>
        <ul class="space-y-2">
          <li class="flex items-start gap-2.5 text-sm text-gray-700">
            <span class="w-1.5 h-1.5 rounded-full bg-gray-400 flex-shrink-0 mt-2"></span>
            <span>보험사 앱 또는 홈페이지에서 <strong>일상배상책임보험</strong> 항목으로 청구하세요</span>
          </li>
          <li class="flex items-start gap-2.5 text-sm text-gray-700">
            <span class="w-1.5 h-1.5 rounded-full bg-gray-400 flex-shrink-0 mt-2"></span>
            <span>다운로드한 PDF 청구서와 누수 피해 사진을 함께 첨부하세요</span>
          </li>
          <li class="flex items-start gap-2.5 text-sm text-gray-700">
            <span class="w-1.5 h-1.5 rounded-full bg-gray-400 flex-shrink-0 mt-2"></span>
            <span>사고 발생일: <strong><%= @insurance_claim.incident_date.strftime("%Y년 %m월 %d일") %></strong></span>
          </li>
          <li class="flex items-start gap-2.5 text-sm text-gray-700">
            <span class="w-1.5 h-1.5 rounded-full bg-gray-400 flex-shrink-0 mt-2"></span>
            <span>제출 완료 후 이 페이지에서 <strong>심사 시작</strong> 버튼을 눌러 진행 상황을 확인하세요</span>
          </li>
        </ul>
      </div>

      <!-- 안내 -->
      <div class="p-4 bg-blue-50 rounded-xl border border-blue-100">
        <p class="text-sm text-blue-900 leading-relaxed">
          보험사에 제출이 완료되면 아래 <strong>심사 시작</strong> 버튼을 눌러주세요. 심사 진행 상황을 이 페이지에서 추적할 수 있습니다.
        </p>
      </div>
    </div>
  </div>
</div>

<script>
function openInsuranceGuide() {
  document.getElementById('insuranceGuideModal').classList.remove('hidden');
  document.body.style.overflow = 'hidden';
}
function closeInsuranceGuide() {
  document.getElementById('insuranceGuideModal').classList.add('hidden');
  document.body.style.overflow = 'auto';
}
function openLightbox(url) {
  document.getElementById('lightbox-claim-img').src = url;
  document.getElementById('lightbox-claim').classList.remove('hidden');
}
function closeLightboxClaim() {
  document.getElementById('lightbox-claim').classList.add('hidden');
}
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    closeInsuranceGuide();
    closeLightboxClaim();
  }
});
</script>

<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <% @static_pages.each do |path| %>
  <url>
    <loc>https://nusucheck.com<%= path %></loc>
    <changefreq>weekly</changefreq>
    <priority><%= path == "/" ? "1.0" : "0.8" %></priority>
  </url>
  <% end %>

  <% @masters.each do |master| %>
  <url>
    <loc>https://nusucheck.com/masters/<%= master.id %></loc>
    <lastmod><%= master.updated_at.strftime("%Y-%m-%d") %></lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.6</priority>
  </url>
  <% end %>

  <% @posts.each do |post| %>
  <url>
    <loc>https://nusucheck.com/posts/<%= post.id %></loc>
    <lastmod><%= post.updated_at.strftime("%Y-%m-%d") %></lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.5</priority>
  </url>
  <% end %>
</urlset>

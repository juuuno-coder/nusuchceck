<div class="space-y-8">
  <!-- 헤더 -->
  <div class="flex items-center justify-between mb-4">
    <h1 class="text-xl font-bold text-gray-900"><%= current_user.name %></h1>
    <%= link_to open_orders_masters_requests_path,
          class: "inline-flex items-center px-3 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors" do %>
      공개 오더
      <% if @open_orders_count > 0 %>
        <span class="ml-2 bg-red-500 text-white text-xs font-bold px-2 py-0.5 rounded-full"><%= @open_orders_count %></span>
      <% end %>
    <% end %>
  </div>

  <!-- 이번 달 누적 수익금 (당근마켓 스타일) -->
  <div class="bg-gradient-to-br from-blue-600 via-blue-700 to-indigo-700 rounded-3xl p-8 shadow-2xl mb-6">
    <div class="text-white">
      <p class="text-sm font-medium text-blue-100 mb-2">이번 달 누적 수익금</p>
      <p class="text-4xl font-extrabold mb-4"><%= number_to_currency(@monthly_settled, unit: "", precision: 0) %> <span class="text-2xl font-bold">원</span></p>
      <div class="flex items-center gap-4 text-sm">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
          </svg>
          <span class="text-blue-100">완료 <%= @monthly_completed %>건</span>
        </div>
        <% if @pending_payout > 0 %>
          <div class="flex items-center gap-2">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
              <path d="M8.433 7.418c.155-.103.346-.196.567-.267v1.698a2.305 2.305 0 01-.567-.267C8.07 8.34 8 8.114 8 8c0-.114.07-.34.433-.582zM11 12.849v-1.698c.22.071.412.164.567.267.364.243.433.468.433.582 0 .114-.07.34-.433.582a2.305 2.305 0 01-.567.267z"/>
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-13a1 1 0 10-2 0v.092a4.535 4.535 0 00-1.676.662C6.602 6.234 6 7.009 6 8c0 .99.602 1.765 1.324 2.246.48.32 1.054.545 1.676.662v1.941c-.391-.127-.68-.317-.843-.504a1 1 0 10-1.51 1.31c.562.649 1.413 1.076 2.353 1.253V15a1 1 0 102 0v-.092a4.535 4.535 0 001.676-.662C13.398 13.766 14 12.991 14 12c0-.99-.602-1.765-1.324-2.246A4.535 4.535 0 0011 9.092V7.151c.391.127.68.317.843.504a1 1 0 101.511-1.31c-.563-.649-1.413-1.076-2.354-1.253V5z" clip-rule="evenodd"/>
            </svg>
            <span class="text-yellow-200">지급대기 <%= number_to_currency(@pending_payout, unit: "", precision: 0) %>원</span>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- 통계 카드 3개 (당근마켓 스타일) -->
  <div class="grid grid-cols-3 gap-4">
    <div class="bg-white rounded-2xl shadow-sm border-2 border-gray-100 p-5 text-center">
      <p class="text-sm font-semibold text-gray-600 mb-2">진행중 오더</p>
      <p class="text-3xl font-extrabold text-blue-600"><%= @active_requests.size %></p>
      <p class="text-xs text-gray-500 mt-1">건</p>
    </div>

    <%
      estimate_pending_count = current_user.assigned_requests
                                           .where(status: :estimate_pending)
                                           .count
    %>
    <div class="bg-white rounded-2xl shadow-sm border-2 border-gray-100 p-5 text-center">
      <p class="text-sm font-semibold text-gray-600 mb-2">견적 대기</p>
      <p class="text-3xl font-extrabold text-orange-600"><%= estimate_pending_count %></p>
      <p class="text-xs text-gray-500 mt-1">건</p>
    </div>

    <%
      total_reviews = current_user.assigned_requests.joins(:review).count
      avg_rating = total_reviews > 0 ? current_user.assigned_requests.joins(:review).average('reviews.rating').to_f : 4.8
      manner_temp = (avg_rating * 10).round(1)
    %>
    <div class="bg-white rounded-2xl shadow-sm border-2 border-gray-100 p-5 text-center">
      <p class="text-sm font-semibold text-gray-600 mb-2">매너온도</p>
      <p class="text-3xl font-extrabold text-green-600"><%= manner_temp %></p>
      <p class="text-xs text-gray-500 mt-1">°C</p>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <!-- 진행 중인 오더 -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900">진행 중인 오더</h2>
        <%= link_to "전체 보기", masters_requests_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
      </div>

      <% if @active_requests.empty? %>
        <div class="text-center py-8">
          <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
          </svg>
          <p class="text-gray-500 text-sm">진행 중인 오더가 없습니다</p>
          <%= link_to "공개 오더 보기", open_orders_masters_requests_path, class: "mt-2 inline-block text-blue-600 text-sm hover:underline" %>
        </div>
      <% else %>
        <div class="space-y-3">
          <% @active_requests.each do |req| %>
            <%
              status_colors = {
                "assigned" => "bg-blue-100 text-blue-700",
                "visiting" => "bg-indigo-100 text-indigo-700",
                "detecting" => "bg-purple-100 text-purple-700",
                "estimate_pending" => "bg-yellow-100 text-yellow-700",
                "estimate_submitted" => "bg-orange-100 text-orange-700",
                "construction_agreed" => "bg-teal-100 text-teal-700",
                "escrow_deposited" => "bg-cyan-100 text-cyan-700",
                "constructing" => "bg-blue-100 text-blue-700",
                "construction_completed" => "bg-green-100 text-green-700"
              }
              badge_class = status_colors[req.status] || "bg-gray-100 text-gray-700"
            %>
            <%= link_to masters_request_path(req), class: "block p-4 rounded-lg border border-gray-100 hover:border-blue-200 hover:bg-blue-50 transition-colors" do %>
              <div class="flex items-center justify-between mb-1">
                <span class="font-medium text-gray-900 text-sm">#<%= req.id %> <%= symptom_label(req.symptom_type) %></span>
                <span class="text-xs font-medium px-2 py-0.5 rounded-full <%= badge_class %>">
                  <%= req.status_label %>
                </span>
              </div>
              <p class="text-xs text-gray-500"><%= req.address.truncate(40) %></p>
              <% if req.preferred_date %>
                <p class="text-xs text-gray-400 mt-1">방문 예정: <%= req.preferred_date.strftime("%m/%d %H:%M") %></p>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>

    <!-- 최근 완료 작업 (포트폴리오) -->
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-lg font-semibold text-gray-900">최근 완료 작업</h2>
        <%= link_to "정산 내역", expert_settlements_path, class: "text-sm text-blue-600 hover:text-blue-800" %>
      </div>

      <% if @recent_completed.empty? %>
        <div class="text-center py-8">
          <svg class="w-12 h-12 text-gray-300 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
          </svg>
          <p class="text-gray-500 text-sm">아직 완료된 작업이 없습니다</p>
        </div>
      <% else %>
        <div class="space-y-3">
          <% @recent_completed.each do |req| %>
            <%= link_to masters_request_path(req), class: "block p-4 rounded-lg border border-gray-100 hover:border-green-200 hover:bg-green-50 transition-colors" do %>
              <div class="flex items-center justify-between mb-1">
                <span class="font-medium text-gray-900 text-sm">#<%= req.id %> <%= symptom_label(req.symptom_type) %></span>
                <% if req.review %>
                  <div class="flex items-center text-yellow-500">
                    <% req.review.rating.times do %>
                      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                      </svg>
                    <% end %>
                  </div>
                <% end %>
              </div>
              <p class="text-xs text-gray-500"><%= req.address.truncate(40) %></p>
              <% settled_amount = req.escrow_transactions.where(status: :settled).sum(:master_payout) %>
              <% if settled_amount > 0 %>
                <p class="text-xs font-medium text-green-600 mt-1">정산: <%= number_to_currency(settled_amount, unit: "₩", precision: 0) %></p>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <!-- 빠른 링크 -->
  <div class="bg-gradient-to-r from-blue-600 to-indigo-600 rounded-xl p-6 text-white">
    <h2 class="text-lg font-semibold mb-4">빠른 메뉴</h2>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      <%= link_to open_orders_masters_requests_path, class: "flex flex-col items-center p-3 bg-white/10 rounded-lg hover:bg-white/20 transition-colors" do %>
        <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
        </svg>
        <span class="text-xs text-center">공개 오더</span>
      <% end %>

      <%= link_to masters_requests_path, class: "flex flex-col items-center p-3 bg-white/10 rounded-lg hover:bg-white/20 transition-colors" do %>
        <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        <span class="text-xs text-center">내 오더</span>
      <% end %>

      <%= link_to expert_settlements_path, class: "flex flex-col items-center p-3 bg-white/10 rounded-lg hover:bg-white/20 transition-colors" do %>
        <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span class="text-xs text-center">정산 내역</span>
      <% end %>

      <%= link_to edit_masters_profile_path, class: "flex flex-col items-center p-3 bg-white/10 rounded-lg hover:bg-white/20 transition-colors" do %>
        <svg class="w-6 h-6 mb-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
        </svg>
        <span class="text-xs text-center">내 프로필</span>
      <% end %>
    </div>
  </div>
</div>

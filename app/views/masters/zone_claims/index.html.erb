<div class="max-w-2xl mx-auto px-4 py-6">

  <div class="mb-6">
    <h1 class="text-xl font-bold text-gray-900">구역 선점</h1>
    <p class="text-sm text-gray-500 mt-1">내 서비스 구역을 선점하세요. 최대 3개 구역까지 선택할 수 있어요.</p>
  </div>

  <!-- 내 선점 구역 -->
  <% if @my_claims.any? %>
    <div class="bg-primary-50 border border-primary-200 rounded-2xl p-4 mb-6">
      <div class="flex items-center justify-between mb-3">
        <h2 class="text-sm font-bold text-primary-800">🏷️ 내 구역</h2>
        <span class="text-xs text-primary-600 font-semibold bg-primary-100 px-2.5 py-0.5 rounded-full"><%= @my_claims.size %>/3</span>
      </div>
      <div class="space-y-2">
        <% @my_claims.each do |claim| %>
          <div class="flex items-center justify-between bg-white rounded-xl px-4 py-3">
            <div>
              <p class="text-sm font-semibold text-gray-900"><%= claim.service_zone.name %></p>
              <p class="text-xs text-gray-400 mt-0.5"><%= claim.service_zone.districts_text %> · <%= claim.service_zone.population_range_text %></p>
            </div>
            <%= link_to masters_zone_claim_path(claim), method: :delete, data: { turbo_confirm: "구역 선점을 해제할까요?" }, class: "text-xs text-red-400 hover:text-red-600 font-medium" do %>
              해제
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <!-- 지역 탭 -->
  <div class="flex gap-2 mb-5 overflow-x-auto pb-1">
    <% @regions.each do |region| %>
      <%= link_to masters_zone_claims_path(region: region),
            class: "px-4 py-2 rounded-full text-sm font-semibold whitespace-nowrap transition-colors #{region == @selected_region ? 'bg-primary-500 text-white shadow-sm' : 'bg-gray-100 text-gray-600 hover:bg-gray-200'}" do %>
        <%= region %>
      <% end %>
    <% end %>
  </div>

  <!-- 구역 목록 -->
  <div class="space-y-3">
    <% @zones.each do |zone| %>
      <% already_claimed = @my_claims.any? { |c| c.service_zone_id == zone.id } %>
      <div class="bg-white border <%= already_claimed ? 'border-primary-300 ring-1 ring-primary-200' : 'border-gray-200' %> rounded-2xl p-4 transition-all">
        <div class="flex items-start justify-between gap-3">
          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 flex-wrap mb-1">
              <p class="text-base font-bold text-gray-900"><%= zone.name %></p>
              <% if already_claimed %>
                <span class="text-[10px] px-2 py-0.5 rounded-full bg-primary-100 text-primary-700 font-bold">선점 중</span>
              <% elsif zone.full? %>
                <span class="text-[10px] px-2 py-0.5 rounded-full bg-red-100 text-red-600 font-semibold">마감</span>
              <% end %>
            </div>
            <p class="text-xs text-gray-500 mb-2"><%= zone.districts_text %></p>

            <!-- 인구 + 슬롯 정보 -->
            <div class="flex items-center gap-3 flex-wrap">
              <span class="inline-flex items-center gap-1 text-xs text-gray-600">
                <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                <span class="font-medium"><%= zone.population_range_text %></span> 권역
              </span>

              <!-- 슬롯 바 -->
              <div class="flex items-center gap-1.5">
                <% zone.max_slots.times do |i| %>
                  <div class="w-5 h-2.5 rounded-full <%= i < zone.claimed_slots_count ? 'bg-primary-400' : 'bg-gray-200' %>"></div>
                <% end %>
                <span class="text-xs <%= zone.full? ? 'text-red-500 font-semibold' : 'text-gray-500' %>">
                  잔여 <%= zone.available_slots %>/<%= zone.max_slots %>
                </span>
              </div>
            </div>
          </div>

          <!-- 액션 버튼 -->
          <div class="flex-shrink-0 mt-0.5">
            <% if already_claimed %>
              <span class="inline-flex items-center gap-1 text-xs text-primary-600 font-semibold px-3 py-2 bg-primary-50 rounded-xl">
                <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                </svg>
                선점 완료
              </span>
            <% elsif zone.full? %>
              <button disabled class="px-3 py-2 bg-gray-100 text-gray-400 text-xs rounded-xl cursor-not-allowed font-medium">마감</button>
            <% elsif @my_claims.size >= 3 %>
              <button disabled class="px-3 py-2 bg-gray-100 text-gray-400 text-xs rounded-xl cursor-not-allowed font-medium">최대 3개</button>
            <% else %>
              <%= link_to masters_zone_claims_path(service_zone_id: zone.id), method: :post,
                    class: "inline-block px-4 py-2 bg-primary-500 text-white text-xs font-bold rounded-xl hover:bg-primary-600 transition-colors" do %>
                선점하기
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    <% end %>
  </div>

  <!-- 안내 -->
  <div class="bg-blue-50 rounded-2xl p-4 mt-6">
    <p class="text-xs font-bold text-blue-800 mb-2">구역 선점 안내</p>
    <ul class="text-xs text-blue-700 space-y-1.5">
      <li class="flex items-start gap-1.5">
        <span class="mt-0.5 flex-shrink-0">•</span>
        월 99,000원 구독료에 구역 선점이 포함돼요
      </li>
      <li class="flex items-start gap-1.5">
        <span class="mt-0.5 flex-shrink-0">•</span>
        선점한 구역의 고객 요청이 우선 매칭돼요
      </li>
      <li class="flex items-start gap-1.5">
        <span class="mt-0.5 flex-shrink-0">•</span>
        슬롯 바(■■□)는 현재 선점 현황이에요 — 빈 슬롯이 있어야 선점 가능해요
      </li>
      <li class="flex items-start gap-1.5">
        <span class="mt-0.5 flex-shrink-0">•</span>
        구독 해지 시 구역 선점이 자동 해제돼요
      </li>
    </ul>
  </div>
</div>
